SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,.railway.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.railway.app,https://yourdomain.com

# ── Local dev ────────────────────────────────────────────
DB_NAME=quest_dnc
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0

# ── Production (Railway auto-injects these) ──────────────
# Railway PostgreSQL plugin sets DATABASE_URL automatically.
# Railway Redis plugin sets REDIS_URL automatically.
# You only need to set the vars below manually.

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (leave EMAIL_BACKEND as console for local dev) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production SMTP (e.g. Gmail app password):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@questdnc.com

# ── Google OAuth (for "Continue with Google" on login/register) ──
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/accounts/social/google/login/callback/
# For local dev add:       http://localhost:8000/accounts/social/google/login/callback/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AWS S3 media storage (leave unset to use local media/ folder) ──
# When set, uploaded files and result CSVs are stored in S3 instead of disk.
AWS_STORAGE_BUCKET_NAME=aws-s3-demo-bucket-check-dnc
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_REGION_NAME=us-west-2
