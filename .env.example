SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,.vercel.app,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.vercel.app,https://yourdomain.com

# ── Local dev (individual vars) ──────────────────────────
DB_NAME=quest_dnc
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Production (Neon / Vercel Postgres) ──────────────────
# Set DATABASE_URL to override the individual vars above
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Redis / Celery
# Local:
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Upstash (production) — use rediss:// for TLS:
# REDIS_URL=rediss://default:password@host:6379
# CELERY_BROKER_URL=rediss://default:password@host:6379
# CELERY_RESULT_BACKEND=rediss://default:password@host:6379

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
